# Copy to config/plant_simulator.env and fill in. plant_simulator.env is gitignored.
# Load before running:  set -a; . config/plant_simulator.env; set +a

# --- Broker (POC: plaintext + username/password) ---
MQTT_HOST=CHANGE_ME_broker_host
MQTT_PORT=1883
MQTT_USERNAME=iot            # publish-only user (ACL: write home/#)
MQTT_PASSWORD=CHANGE_ME
MQTT_QOS=1
USE_TLS=false

# --- Fleet ---
TOPIC_PREFIX=home/plants     # must stay under home/# (iot user ACL)
FLEET_DEVICES=0              # 0 = full fleet (200); set lower for testing
INTERVAL_SCALE=1.0           # 2.0 halves the message rate
ANOMALY_RATE=1.5             # anomaly events / device / day (chronic devices 4x)
SIM_SEED=42
SIM_DURATION=0               # 0 = run until Ctrl-C
