# Copy to config/simulator.env and fill in. simulator.env is gitignored (real password).
# Load before running:  set -a; . config/simulator.env; set +a

# --- Broker (POC: plaintext + username/password) ---
MQTT_HOST=CHANGE_ME_cloud_vm_public_ip   # cloud VM running Mosquitto (see config/secrets.env)
MQTT_PORT=1883
MQTT_USERNAME=iot
MQTT_PASSWORD=IoTsensor@26     # the 'iot' user created on the Mosquitto broker (Phase 2)

# --- Publishing ---
PUBLISH_INTERVAL=300          # 5 minutes. Use 5 while testing so you see output fast.
DEVICE_ID=sim_temp_01
DEVICE_NAME="Simulated Temp Sensor"
DISCOVERY_PREFIX=homeassistant

# --- Dummy temperature model ---
BASE_TEMP=22.0
DRIFT=0.3
TMIN=16.0
TMAX=30.0

# --- TLS (production; leave off for POC) ---
USE_TLS=false
# TLS_CA_CERT=config/certs/ca.crt
# TLS_CLIENT_CERT=config/certs/client.crt
# TLS_CLIENT_KEY=config/certs/client.key
# TLS_INSECURE=false
